msgstr "Path root yang dipilih: %s"

#: cmd/quickstart.py:245
msgid "Enter the root path for documentation."
msgstr "Masukkan jalur root untuk dokumentasi."

#: cmd/quickstart.py:246
msgid "Root path for the documentation"
